{
  "name": "flowstack-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,yellow \"vite\" \"doppler run --project fulfillment-automation --config dev_claudio -- python3 demo-backend/server.py\"",
    "dev:frontend": "vite",
    "build": "tsc -b && vite build",
